rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isCoupleMember(coupleId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create, delete: if isSelf(uid);
      allow update: if isSelf(uid)
        || (
          signedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coupleId'])
        );
    }

    match /couples/{coupleId} {
      allow create: if signedIn()
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members;

      allow read, update, delete: if signedIn()
        && request.auth.uid in resource.data.members;

      match /{subcollection}/{docId} {
        allow read, write: if isCoupleMember(coupleId);
      }
    }
  }
}
