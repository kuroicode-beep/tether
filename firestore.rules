rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users: 본인 문서만 쓰기 — coupleId cross-update 금지
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // invites: 1회용 커플 연결 토큰 — 생성/조회만 클라이언트 허용, claim은 Cloud Function
    match /invites/{code} {
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.claimed == false;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // couples: 멤버만 read/update — create는 Admin SDK(claimInvite) 전용
    match /couples/{coupleId} {
      function isMember() {
        return request.auth != null
               && resource != null
               && resource.data.members is list
               && request.auth.uid in resource.data.members;
      }

      function coupleMembers() {
        return get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
      }

      function isCoupleMember() {
        return request.auth != null
               && request.auth.uid in coupleMembers();
      }

      allow read: if isMember();
      allow create: if false;
      allow update: if isMember()
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['members']);
      allow delete: if false;

      // status: 본인 문서만 create/update
      match /status/{uid} {
        allow read: if isCoupleMember();
        allow create, update: if isCoupleMember() && request.auth.uid == uid;
        allow delete: if false;
      }

      // statusHistory: append-only, uid 위조 금지
      match /statusHistory/{entryId} {
        allow read: if isCoupleMember();
        allow create: if isCoupleMember()
                      && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }

      // messages: 작성자 create/delete, readBy는 수신자도 갱신 가능
      match /messages/{messageId} {
        function isReadByOnlyUpdate() {
          return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']);
        }

        allow read: if isCoupleMember();
        allow create: if isCoupleMember()
                      && request.resource.data.senderUid == request.auth.uid;
        allow update: if isCoupleMember()
                      && (
                        resource.data.senderUid == request.auth.uid
                        || isReadByOnlyUpdate()
                      );
        allow delete: if isCoupleMember()
                      && resource.data.senderUid == request.auth.uid;
      }

      // diary: 작성자 create/update/delete, isRead는 읽는 파트너도 true로 갱신 가능
      match /diary/{diaryId} {
        function isDiaryReadOnlyUpdate() {
          return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])
                 && request.resource.data.isRead == true;
        }

        allow read: if isCoupleMember();
        allow create: if isCoupleMember()
                      && request.resource.data.authorUid == request.auth.uid;
        allow update: if isCoupleMember()
                      && (
                        resource.data.authorUid == request.auth.uid
                        || isDiaryReadOnlyUpdate()
                      );
        allow delete: if isCoupleMember()
                      && resource.data.authorUid == request.auth.uid;
      }

      match /photos/{photoId} {
        allow read, write: if isCoupleMember();
      }

      match /contents/{contentId} {
        allow read, write: if isCoupleMember();
      }

      match /history/{itemId} {
        allow read: if isCoupleMember();
        allow create: if isCoupleMember()
                      && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if isCoupleMember()
                              && resource.data.authorUid == request.auth.uid;
      }
    }
  }
}
