rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function myCoupleId() {
      return request.auth != null
             && userDoc(request.auth.uid).data.keys().hasAny(['coupleId'])
             && userDoc(request.auth.uid).data.coupleId is string
             ? userDoc(request.auth.uid).data.coupleId
             : null;
    }

    function isPartnerUser(uid) {
      return request.auth != null
             && request.auth.uid != uid
             && myCoupleId() != null
             && userDoc(uid).data.keys().hasAny(['coupleId'])
             && userDoc(uid).data.coupleId == myCoupleId();
    }

    // Invite preview nickname.
    match /publicProfiles/{uid} {
      function validPublicProfileWrite() {
        return request.resource.data.keys().hasOnly(['nickname', 'photoUrl'])
               && request.resource.data.nickname is string
               && request.resource.data.nickname.size() > 0
               && request.resource.data.nickname.size() <= 40
               && (
                 !request.resource.data.keys().hasAny(['photoUrl'])
                 || request.resource.data.photoUrl == null
                 || request.resource.data.photoUrl is string
               );
      }

      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.auth.uid == uid
                            && validPublicProfileWrite();
      allow delete: if false;
    }

    // User docs: self and coupled partner can read; clients cannot mutate coupleId.
    match /users/{uid} {
      function coupleIdUnchanged() {
        return request.resource.data.coupleId == resource.data.coupleId;
      }

      function validUserCreate() {
        return !('coupleId' in request.resource.data)
               || request.resource.data.coupleId == null;
      }

      function userMutableKeysOnly() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'nickname',
          'inviteCode',
          'fcmToken',
          'fcmTokens',
          'fcmUpdatedAt',
          'notificationSettings',
          'lastRead',
          'photoUrl',
        ]);
      }

      allow read: if request.auth != null
                  && (request.auth.uid == uid || isPartnerUser(uid));
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && validUserCreate();
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && coupleIdUnchanged()
                    && userMutableKeysOnly();
      allow delete: if false;
    }

    // Invites: clients create/read tokens; claim runs through Cloud Functions.
    match /invites/{code} {
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.claimed == false;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // Couples: members read/update, creation is Admin SDK only.
    match /couples/{coupleId} {
      function isMember() {
        return request.auth != null
               && resource != null
               && resource.data.members is list
               && request.auth.uid in resource.data.members;
      }

      function coupleMembers() {
        return get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
      }

      function isCoupleMember() {
        return request.auth != null
               && request.auth.uid in coupleMembers();
      }

      allow read: if isMember();
      allow create: if false;
      allow update: if isMember()
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['members']);
      allow delete: if false;

      // Status: users can write only their own status document.
      match /status/{uid} {
        allow read: if isCoupleMember();
        allow create, update: if isCoupleMember() && request.auth.uid == uid;
        allow delete: if false;
      }

      // Status history is append-only and uid must match the writer.
      match /statusHistory/{entryId} {
        allow read: if isCoupleMember();
        allow create: if isCoupleMember()
                      && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }

      // Messages: sender edits text; recipient can only add their own readBy uid.
      match /messages/{messageId} {
        function previousReadBy() {
          return resource.data.keys().hasAny(['readBy']) && resource.data.readBy is list
                 ? resource.data.readBy
                 : [];
        }

        function isReadByOnlyUpdate() {
          return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']);
        }

        function isValidMessageCreate() {
          return request.resource.data.senderUid == request.auth.uid
                 && request.resource.data.readBy is list
                 && request.resource.data.readBy.size() == 1
                 && request.resource.data.readBy[0] == request.auth.uid;
        }

        function isSenderTextEdit() {
          return resource.data.senderUid == request.auth.uid
                 && request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['text', 'editedAt']);
        }

        function isRecipientReadByUpdate() {
          return resource.data.senderUid != request.auth.uid
                 && isReadByOnlyUpdate()
                 && request.resource.data.readBy is list
                 && !(request.auth.uid in previousReadBy())
                 && request.auth.uid in request.resource.data.readBy
                 && request.resource.data.readBy.size() == previousReadBy().size() + 1
                 && request.resource.data.readBy.hasAll(previousReadBy());
        }

        allow read: if isCoupleMember();
        allow create: if isCoupleMember() && isValidMessageCreate();
        allow update: if isCoupleMember()
                      && (isSenderTextEdit() || isRecipientReadByUpdate());
        allow delete: if isCoupleMember()
                      && resource.data.senderUid == request.auth.uid;
      }

      // Diary: author owns entries; partner may only mark as read.
      match /diary/{diaryId} {
        function isDiaryReadOnlyUpdate() {
          return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])
                 && request.resource.data.isRead == true;
        }

        allow read: if isCoupleMember();
        allow create: if isCoupleMember()
                      && request.resource.data.authorUid == request.auth.uid;
        allow update: if isCoupleMember()
                      && (
                        resource.data.authorUid == request.auth.uid
                        || isDiaryReadOnlyUpdate()
                      );
        allow delete: if isCoupleMember()
                      && resource.data.authorUid == request.auth.uid;
      }

      // Photos: uploadedBy owns create/update/delete; only caption is editable.
      match /photos/{photoId} {
        function isPhotoOwnerCreate() {
          return request.resource.data.uploadedBy == request.auth.uid;
        }

        function isPhotoOwner() {
          return resource.data.uploadedBy == request.auth.uid;
        }

        function isOwnerCaptionUpdate() {
          return isPhotoOwner()
                 && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['caption']);
        }

        allow read: if isCoupleMember();
        allow create: if isCoupleMember() && isPhotoOwnerCreate();
        allow update: if isCoupleMember() && isOwnerCaptionUpdate();
        allow delete: if isCoupleMember() && isPhotoOwner();
      }

      // Contents: addedBy owns the item; partner can update status fields only.
      match /contents/{contentId} {
        function isContentOwnerCreate() {
          return request.resource.data.addedBy == request.auth.uid;
        }

        function isContentOwner() {
          return resource.data.addedBy == request.auth.uid;
        }

        function isOwnerContentUpdate() {
          return isContentOwner()
                 && !request.resource.data.diff(resource.data).affectedKeys()
                       .hasAny(['addedBy', 'createdAt']);
        }

        function isPartnerStatusUpdate() {
          return resource.data.addedBy != request.auth.uid
                 && request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['status', 'rating', 'review', 'updatedAt']);
        }

        allow read: if isCoupleMember();
        allow create: if isCoupleMember() && isContentOwnerCreate();
        allow update: if isCoupleMember()
                      && (isOwnerContentUpdate() || isPartnerStatusUpdate());
        allow delete: if isCoupleMember() && isContentOwner();
      }

      // History: authorUid owns create/update/delete.
      match /history/{itemId} {
        allow read: if isCoupleMember();
        allow create: if isCoupleMember()
                      && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if isCoupleMember()
                              && resource.data.authorUid == request.auth.uid;
      }
    }
  }
}
