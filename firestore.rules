rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users: 본인 문서만 쓰기 — coupleId cross-update 금지
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // invites: 1회용 커플 연결 토큰 — 생성/조회만 클라이언트 허용, claim은 Cloud Function
    match /invites/{code} {
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.claimed == false;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // couples: 멤버만 read/update — create는 Admin SDK(claimInvite) 전용
    match /couples/{coupleId} {
      function isMember() {
        return request.auth != null
               && resource != null
               && resource.data.members is list
               && request.auth.uid in resource.data.members;
      }

      allow read: if isMember();
      allow create: if false;
      allow update: if isMember()
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['members']);
      allow delete: if false;

      match /{subcollection}/{docId} {
        function coupleMembers() {
          return get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
        }

        allow read, write: if request.auth != null
                           && request.auth.uid in coupleMembers();
      }
    }
  }
}
