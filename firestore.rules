rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function canonicalCoupleId(uidA, uidB) {
      return uidA < uidB ? uidA + '_' + uidB : uidB + '_' + uidA;
    }

    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;

      function isValidCoupleIdCrossLink() {
        let cid = request.resource.data.coupleId;
        let wasUnlinked = !('coupleId' in resource.data)
          || resource.data.coupleId == null
          || resource.data.coupleId == '';
        return wasUnlinked &&
          cid is string &&
          cid.size() > 0 &&
          cid == canonicalCoupleId(request.auth.uid, uid);
      }

      allow update: if request.auth != null && (
        request.auth.uid == uid ||
        (
          resource != null &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coupleId']) &&
          isValidCoupleIdCrossLink()
        )
      );

      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    match /couples/{coupleId} {
      function isMember() {
        return request.auth != null &&
          resource != null &&
          resource.data.members is list &&
          request.auth.uid in resource.data.members;
      }

      function isMemberOfNew() {
        return request.auth != null &&
          request.resource.data.members is list &&
          request.resource.data.members.size() == 2 &&
          request.auth.uid in request.resource.data.members;
      }

      allow read: if request.auth != null && (
        resource == null ||
        request.auth.uid in resource.data.members
      );

      allow create: if isMemberOfNew();

      allow update: if isMember() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['members']);

      allow delete: if false;

      match /{subcollection}/{docId} {
        function coupleMembers() {
          return get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
        }

        allow read, write: if request.auth != null &&
          request.auth.uid in coupleMembers();
      }
    }
  }
}
