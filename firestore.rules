rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isAdmin() {
      return request.auth != null
             && request.auth.token.email == 'kuroicode@gmail.com';
    }

    function myCoupleId() {
      return request.auth != null
             && userDoc(request.auth.uid).data.keys().hasAny(['coupleId'])
             && userDoc(request.auth.uid).data.coupleId is string
             ? userDoc(request.auth.uid).data.coupleId
             : null;
    }

    function isPartnerUser(uid) {
      return request.auth != null
             && request.auth.uid != uid
             && myCoupleId() != null
             && userDoc(uid).data.keys().hasAny(['coupleId'])
             && userDoc(uid).data.coupleId == myCoupleId();
    }

    // Invite preview nickname.
    match /publicProfiles/{uid} {
      function validPublicProfileWrite() {
        return request.resource.data.keys().hasOnly(['nickname', 'photoUrl'])
               && request.resource.data.nickname is string
               && request.resource.data.nickname.size() > 0
               && request.resource.data.nickname.size() <= 40
               && (
                 !request.resource.data.keys().hasAny(['photoUrl'])
                 || request.resource.data.photoUrl == null
                 || request.resource.data.photoUrl is string
               );
      }

      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.auth.uid == uid
                            && validPublicProfileWrite();
      allow delete: if false;
    }

    match /adminConfig/{configId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /{path=**}/feedbackReports/{reportId} {
      allow read: if isAdmin();
    }

    // User docs: self and coupled partner can read; clients cannot mutate coupleId.
    match /users/{uid} {
      function isGoogleAuth() {
        return request.auth.token.firebase.sign_in_provider == 'google.com';
      }

      function coupleIdUnchanged() {
        return request.resource.data.coupleId == resource.data.coupleId;
      }

      function validUserCreate() {
        return (!('coupleId' in request.resource.data)
                || request.resource.data.coupleId == null)
               && (
                 !request.resource.data.keys().hasAny(['approved'])
                 || request.resource.data.approved == false
                 || (isAdmin() && request.resource.data.approved == true)
               )
               && (
                 !request.resource.data.keys().hasAny(['role'])
                 || request.resource.data.role == 'member'
                 || (isAdmin() && request.resource.data.role == 'admin')
               )
               && (
                 !request.resource.data.keys().hasAny(['approvedAt'])
                 || request.resource.data.approvedAt == null
                 || (isAdmin() && request.resource.data.approvedAt is timestamp)
               )
               && (
                 !request.resource.data.keys().hasAny(['approvedBy'])
                 || request.resource.data.approvedBy == null
                 || isAdmin()
               );
      }

      function userMutableKeysOnly() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'nickname',
          'inviteCode',
          'fcmToken',
          'fcmTokens',
          'fcmUpdatedAt',
          'notificationSettings',
          'lastRead',
          'photoUrl',
        ]);
      }

      function adminMutableKeysOnly() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'approved',
          'approvedAt',
          'approvedBy',
          'role',
        ]);
      }

      allow read: if request.auth != null
                  && (isAdmin() || request.auth.uid == uid || isPartnerUser(uid));
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && isGoogleAuth()
                    && validUserCreate();
      allow update: if request.auth != null
                    && (
                      (
                        request.auth.uid == uid
                        && coupleIdUnchanged()
                        && userMutableKeysOnly()
                      )
                      || (isAdmin() && adminMutableKeysOnly())
                    );
      allow delete: if false;
    }

    // Invites: clients create/read tokens; claim runs through Cloud Functions.
    match /invites/{code} {
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.claimed == false;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // Couples: members read/update, creation is Admin SDK only.
    match /couples/{coupleId} {
      function isMember() {
        return request.auth != null
               && resource != null
               && resource.data.members is list
               && request.auth.uid in resource.data.members;
      }

      function coupleMembers() {
        return get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
      }

      function isCoupleMember() {
        return request.auth != null
               && request.auth.uid in coupleMembers();
      }

      allow read: if isMember();
      allow create: if false;
      allow update: if isMember()
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['members']);
      allow delete: if false;

      // Status: users can write only their own status document.
      match /status/{uid} {
        allow read: if isCoupleMember();
        allow create, update: if isCoupleMember() && request.auth.uid == uid;
        allow delete: if false;
      }

      // Status history is append-only and uid must match the writer.
      match /statusHistory/{entryId} {
        allow read: if isCoupleMember();
        allow create: if isCoupleMember()
                      && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }

      // Messages: sender edits text; recipient can only add their own readBy uid.
      match /messages/{messageId} {
        function previousReadBy() {
          return resource.data.keys().hasAny(['readBy']) && resource.data.readBy is list
                 ? resource.data.readBy
                 : [];
        }

        function isReadByOnlyUpdate() {
          return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']);
        }

        function isValidMessageCreate() {
          return request.resource.data.senderUid == request.auth.uid
                 && request.resource.data.readBy is list
                 && request.resource.data.readBy.size() == 1
                 && request.resource.data.readBy[0] == request.auth.uid;
        }

        function isSenderTextEdit() {
          return resource.data.senderUid == request.auth.uid
                 && request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['text', 'editedAt']);
        }

        function isRecipientReadByUpdate() {
          return resource.data.senderUid != request.auth.uid
                 && isReadByOnlyUpdate()
                 && request.resource.data.readBy is list
                 && !(request.auth.uid in previousReadBy())
                 && request.auth.uid in request.resource.data.readBy
                 && request.resource.data.readBy.size() == previousReadBy().size() + 1
                 && request.resource.data.readBy.hasAll(previousReadBy());
        }

        allow read: if isCoupleMember();
        allow create: if isCoupleMember() && isValidMessageCreate();
        allow update: if isCoupleMember()
                      && (isSenderTextEdit() || isRecipientReadByUpdate());
        allow delete: if isCoupleMember()
                      && resource.data.senderUid == request.auth.uid;
      }

      // Files: durable library index copied from chat file messages.
      match /files/{fileId} {
        function validFileCreate() {
          return request.resource.data.senderUid == request.auth.uid
                 && request.resource.data.fileUrl is string
                 && request.resource.data.fileName is string
                 && request.resource.data.fileType is string
                 && request.resource.data.createdAt is timestamp;
        }

        allow read: if isCoupleMember();
        allow create: if isCoupleMember() && validFileCreate();
        allow update: if false;
        allow delete: if isCoupleMember()
                      && resource.data.senderUid == request.auth.uid;
      }

      // Diary: author owns entries; partner may mark read or write one reply.
      match /diary/{diaryId} {
        function hasNoReply() {
          return !resource.data.keys().hasAny(['reply']) || resource.data.reply == null;
        }

        function isDiaryReadOnlyUpdate() {
          return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])
                 && request.resource.data.isRead == true;
        }

        function isDiaryReplyCreate() {
          return resource.data.authorUid != request.auth.uid
                 && hasNoReply()
                 && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reply'])
                 && request.resource.data.reply is map
                 && request.resource.data.reply.keys().hasAll(['authorUid', 'content', 'createdAt'])
                 && request.resource.data.reply.authorUid == request.auth.uid
                 && request.resource.data.reply.content is string
                 && request.resource.data.reply.content.size() > 0
                 && request.resource.data.reply.content.size() <= 4000
                 && (
                   !request.resource.data.reply.keys().hasAny(['imageUrl'])
                   || request.resource.data.reply.imageUrl == null
                   || request.resource.data.reply.imageUrl is string
                 )
                 && (
                   !request.resource.data.reply.keys().hasAny(['clientId'])
                   || request.resource.data.reply.clientId is string
                 );
        }

        allow read: if isCoupleMember();
        allow create: if isCoupleMember()
                      && request.resource.data.authorUid == request.auth.uid;
        allow update: if isCoupleMember()
                      && (
                        resource.data.authorUid == request.auth.uid
                        || isDiaryReadOnlyUpdate()
                        || isDiaryReplyCreate()
                      );
        allow delete: if isCoupleMember()
                      && resource.data.authorUid == request.auth.uid;
      }

      // Photos: uploadedBy owns create/update/delete; only caption is editable.
      match /photos/{photoId} {
        function isPhotoOwnerCreate() {
          return request.resource.data.uploadedBy == request.auth.uid;
        }

        function isPhotoOwner() {
          return resource.data.uploadedBy == request.auth.uid;
        }

        function isOwnerCaptionUpdate() {
          return isPhotoOwner()
                 && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['caption']);
        }

        allow read: if isCoupleMember();
        allow create: if isCoupleMember() && isPhotoOwnerCreate();
        allow update: if isCoupleMember() && isOwnerCaptionUpdate();
        allow delete: if isCoupleMember() && isPhotoOwner();
      }

      // Contents: addedBy owns the item; partner can update status fields only.
      match /contents/{contentId} {
        function isContentOwnerCreate() {
          return request.resource.data.addedBy == request.auth.uid;
        }

        function isContentOwner() {
          return resource.data.addedBy == request.auth.uid;
        }

        function isOwnerContentUpdate() {
          return isContentOwner()
                 && !request.resource.data.diff(resource.data).affectedKeys()
                       .hasAny(['addedBy', 'createdAt']);
        }

        function isPartnerStatusUpdate() {
          return resource.data.addedBy != request.auth.uid
                 && request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['status', 'rating', 'review', 'updatedAt']);
        }

        allow read: if isCoupleMember();
        allow create: if isCoupleMember() && isContentOwnerCreate();
        allow update: if isCoupleMember()
                      && (isOwnerContentUpdate() || isPartnerStatusUpdate());
        allow delete: if isCoupleMember() && isContentOwner();
      }

      // History: authorUid owns create/update/delete.
      match /history/{itemId} {
        allow read: if isCoupleMember();
        allow create: if isCoupleMember()
                      && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if isCoupleMember()
                              && resource.data.authorUid == request.auth.uid;
      }

      // Feedback reports: couple-shared Log memos with author-owned deletion.
      match /feedbackReports/{reportId} {
        function validFeedbackType() {
          return request.resource.data.type in ['improvement', 'bug'];
        }

        function validFeedbackStatus() {
          return request.resource.data.status in ['open', 'done'];
        }

        function validFeedbackText() {
          return request.resource.data.text is string
                 && request.resource.data.text.size() > 0
                 && request.resource.data.text.size() <= 500;
        }

        function validFeedbackCreate() {
          return request.resource.data.keys().hasOnly([
                   'clientId',
                   'type',
                   'text',
                   'status',
                   'authorUid',
                   'authorNickname',
                   'createdAt',
                 ])
                 && request.resource.data.clientId is string
                 && request.resource.data.clientId.size() > 0
                 && request.resource.data.authorUid == request.auth.uid
                 && request.resource.data.authorNickname is string
                 && request.resource.data.authorNickname.size() > 0
                 && request.resource.data.authorNickname.size() <= 40
                 && validFeedbackType()
                 && validFeedbackText()
                 && request.resource.data.status == 'open'
                 && request.resource.data.createdAt is timestamp;
        }

        function validFeedbackUpdate() {
          return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                   'status',
                   'updatedAt',
                   'doneAt',
                   'doneBy',
                 ])
                 && validFeedbackStatus()
                 && (!request.resource.data.keys().hasAny(['updatedAt'])
                     || request.resource.data.updatedAt is timestamp)
                 && (!request.resource.data.keys().hasAny(['doneAt'])
                     || request.resource.data.doneAt == null
                     || request.resource.data.doneAt is timestamp)
                 && (!request.resource.data.keys().hasAny(['doneBy'])
                     || request.resource.data.doneBy == null
                     || request.resource.data.doneBy == request.auth.uid);
        }

        allow read: if isCoupleMember();
        allow create: if isCoupleMember() && validFeedbackCreate();
        allow update: if isCoupleMember() && validFeedbackUpdate();
        allow delete: if isCoupleMember()
                      && resource.data.authorUid == request.auth.uid;
      }

      // Shared links: couple members read; author owns writes.
      match /links/{linkId} {
        function validLinkText() {
          return request.resource.data.title is string
                 && request.resource.data.title.size() > 0
                 && request.resource.data.title.size() <= 120
                 && request.resource.data.url is string
                 && request.resource.data.url.size() > 0
                 && request.resource.data.url.size() <= 1000
                 && (
                   !request.resource.data.keys().hasAny(['summary'])
                   || request.resource.data.summary == null
                   || (
                     request.resource.data.summary is string
                     && request.resource.data.summary.size() <= 1000
                   )
                 );
        }

        function validLinkCreate() {
          return request.resource.data.createdBy == request.auth.uid
                 && validLinkText();
        }

        function isLinkOwner() {
          return resource.data.createdBy == request.auth.uid;
        }

        allow read: if isCoupleMember();
        allow create: if isCoupleMember() && validLinkCreate();
        allow update, delete: if isCoupleMember() && isLinkOwner();
      }

      // Date recipes: couple members read; author owns writes.
      match /dateRecipes/{recipeId} {
        function validRecipeText() {
          return request.resource.data.date is string
                 && request.resource.data.date.size() >= 8
                 && request.resource.data.date.size() <= 20
                 && request.resource.data.food is string
                 && request.resource.data.food.size() > 0
                 && request.resource.data.food.size() <= 120
                 && (
                   !request.resource.data.keys().hasAny(['memo'])
                   || request.resource.data.memo == null
                   || (
                     request.resource.data.memo is string
                     && request.resource.data.memo.size() <= 500
                   )
                 );
        }

        function validRecipeCreate() {
          return request.resource.data.createdBy == request.auth.uid
                 && validRecipeText();
        }

        function isRecipeOwner() {
          return resource.data.createdBy == request.auth.uid;
        }

        allow read: if isCoupleMember();
        allow create: if isCoupleMember() && validRecipeCreate();
        allow update, delete: if isCoupleMember() && isRecipeOwner();
      }
    }
  }
}
