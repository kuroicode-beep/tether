rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── 커플 사진 스토리지 ───────────────────────────────────────────────────
    // 경로: couples/{coupleId}/photos/{filename}
    match /couples/{coupleId}/photos/{filename} {
      allow read, write: if request.auth != null &&
        request.auth.uid in
          firestore.get(/databases/(default)/documents/couples/$(coupleId)).data.members;
    }

    // ── 기타 커플 미디어 (확장성) ────────────────────────────────────────────
    match /couples/{coupleId}/{allPaths=**} {
      allow read, write: if request.auth != null &&
        request.auth.uid in
          firestore.get(/databases/(default)/documents/couples/$(coupleId)).data.members;
    }
  }
}
