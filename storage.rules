rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isCoupleMember(coupleId) {
      return request.auth != null
             && firestore.exists(/databases/(default)/documents/couples/$(coupleId))
             && firestore.get(/databases/(default)/documents/couples/$(coupleId)).data.members is list
             && firestore.get(/databases/(default)/documents/couples/$(coupleId)).data.members.hasAny([request.auth.uid]);
    }

    // Chat images: couples/{coupleId}/images/{filename}
    match /couples/{coupleId}/images/{filename} {
      allow read, write: if isCoupleMember(coupleId);
    }

    // Photo album media: couples/{coupleId}/photos/{filename}
    match /couples/{coupleId}/photos/{uploaderUid}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uploaderUid;
    }

    // Legacy photo album media: couples/{coupleId}/photos/{filename}
    match /couples/{coupleId}/photos/{filename} {
      allow read, write: if isCoupleMember(coupleId);
    }

    // Diary media: couples/{coupleId}/diary/{...}
    match /couples/{coupleId}/diary/{allPaths=**} {
      allow read, write: if isCoupleMember(coupleId);
    }

    // History media: couples/{coupleId}/history/{...}
    match /couples/{coupleId}/history/{allPaths=**} {
      allow read, write: if isCoupleMember(coupleId);
    }
  }
}
